									'operator': _macros_sparksql.Retrieve,
									'modelType': 'urn:healthit-gov:qdm:v5_6',
									'valueSet': none, 'templateId': 'PositiveEncounterPerformed',
									'children': [
										{
											'operator': _macros_sparksql.ValueSetRef,
											'children': []
