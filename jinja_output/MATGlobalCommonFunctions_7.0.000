{#
	// MATGlobalCommonFunctions lines [47:1-51:18]
	define function "EmergencyDepartmentArrivalTime"(Encounter "Encounter, Performed" ):
	  start of First(("HospitalizationLocations"(Encounter))HospitalLocation
