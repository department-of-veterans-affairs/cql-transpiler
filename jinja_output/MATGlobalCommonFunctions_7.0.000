{#
	// MATGlobalCommonFunctions lines [133:1-138:3]
	define function "FirstInpatientIntensiveCareUnit"(Encounter "Encounter, Performed" ):
	  First((Encounter.facilityLocations)HospitalLocation
	      where HospitalLocation.code in "Intensive Care Unit"
	        and HospitalLocation.locationPeriod during Encounter.relevantPeriod
	      sort by start of locationPeriod
	  )
#}
{% macro FirstInpatientIntensiveCareUnit(Encounter) %}{{ macros.First(macros.Query([], [macros.AliasedQuerySource('HospitalLocation', macros.Property('LAZY_EVALUATION', none, 'facilityLocations', Encounter)), macros.And(macros.InValueSet(macros.Property('COLUMN_REFERENCE', 'HospitalLocation', 'code', none), macros.ValueSetRef()), macros.IncludedIn(macros.Property('COLUMN_REFERENCE', 'HospitalLocation', 'locationPeriod', none), macros.Property('LAZY_EVALUATION', none, 'relevantPeriod', Encounter)))], none, none, macros.SortClause([macros.ByExpression('ASC', macros.Start(macros.IdentifierRef('locationPeriod')))]))) }}{% endmacro %}
{#
	// MATGlobalCommonFunctions lines [141:1-144:35]
	define function "NormalizeInterval"(pointInTime DateTime, period Interval<DateTime> ):
	  if pointInTime is not null then Interval[pointInTime, pointInTime]
	    else if period is not null then period 
	    else null as Interval<DateTime>
#}
{% macro NormalizeInterval(pointInTime, period) %}{{ macros.If(macros.Not(macros.IsNull(pointInTime)), macros.Interval(pointInTime, pointInTime), macros.If(macros.Not(macros.IsNull(period)), period, macros.As(macros.Null(), macros.IntervalTypeSpecifier(macros.NamedTypeSpecifier())))) }}{% endmacro %}
{#
	// MATGlobalCommonFunctions lines [147:1-150:3]
	define function "HasStart"(period Interval<DateTime> ):
	  not ( start of period is null
	      or start of period = minimum DateTime
	  )
#}
{% macro HasStart(period) %}{{ macros.Not(macros.Or(macros.IsNull(macros.Start(period)), macros.Equal(macros.Start(period), macros.MinValue()))) }}{% endmacro %}
{#
	// MATGlobalCommonFunctions lines [153:1-158:3]
	define function "HasEnd"(period Interval<DateTime> ):
	  not ( 
	    end of period is null
	      or 
	      end of period = maximum DateTime
	  )
#}
{% macro HasEnd(period) %}{{ macros.Not(macros.Or(macros.IsNull(macros.End(period)), macros.Equal(macros.End(period), macros.MaxValue()))) }}{% endmacro %}
{#
	// MATGlobalCommonFunctions lines [161:1-164:24]
	define function "Latest"(period Interval<DateTime> ):
	  if ( HasEnd(period)) then 
	  end of period 
	    else start of period
#}
{% macro Latest(period) %}{{ macros.If(HasEnd(period), macros.End(period), macros.Start(period)) }}{% endmacro %}
{#
	// MATGlobalCommonFunctions lines [167:1-170:15]
