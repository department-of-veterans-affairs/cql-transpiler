#}

{%- set OperatorHandlerClass = namespace() %}

{%- macro operatorHandlerPrint(state, arguments) %}
{%- if state == none %}
{%- set state = namespace() %}
{%- do StateClass.construct(state) %}
{%- endif %}
{%- set operatorDataType = namespace() %}
{%- do arguments['operator'].getDataType(arguments['operator'], operatorDataType, state, arguments) %}
{%- if state.coercionInstructions[operatorDataType] != none %}
{{ coerce(operatorDataType, state.coercionInstructions[operatorDataType], state, arguments) }}
{%- else %}
{{ arguments['operator'].print(arguments['operator'], state, arguments) }}
{%- endif %}
{%- endmacro %}

{%- macro OperatorHandlerConstruct(operatorHandlerNamespace) %}
{%- set operatorHandlerNamespace.print = operatorHandlerPrint %}
{%- endmacro %}
