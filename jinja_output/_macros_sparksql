{# DOCUMENTATION #}
{#
    State contains the following scoped variables:
        coercionInstructions - Dictionary<String, String>
        context - String
        insideQuery - Boolean
        functionArguments - Dictionary<String, Dictionary<String, ?>

    Whenever one of these variables are set, the following standard should be performed:
    {% set previousVariableName = state.variableName %}{% set state.variableName = newValue %}{{ function(state) }}{% set state.variableName = previousVariableName %}

    Potential data types:
        SIMPLE
        ENCAPSULATED
        TABLE
        INHERITED
        STATEMENT
        UNKNOWN
#}

{# UTILITY AND HELPER FUNCTIONS #}

{# initializes state #}
{% macro InitState(state) %}
{% set state.coercionInstructions = {} %}
{% set state.context = none %}
{% set state.insideQuery = false %}
{% set state.functionArguments = {} %}
{% endmacro %}

{# Utility function to get the column a context should be grouped by #}
{% macro GetIDFromContext(context) %}{{ context }}id{% endmacro %}

{# Standards #}
{% macro EmptyTable() %}SELECT * FROM (SELECT 1 _val) WHERE _val = 0{% endmacro %}

{# Utility functions for printing lists #}
{% macro ListPrintingUtility(listOfItemsToPrint, joiner) %}{% set ns = namespace(first = true) %}{% for item in listOfItemsToPrint %}{% if ns.first %}{% set ns.first = false %}{% else %}{{ joiner }}{% endif %}{{ item }}{% endfor %}{% endmacro %}
{%- macro ArgumentListPrintingUtility(state, listOfArgumentsToPrint, joiner) %}
{%- set ns = namespace(first = true) %}
{%- for item in listOfArgumentsToPrint %}
{%- if ns.first %}
{%- set ns.first = false %}
{%- else %}
{{ joiner }}
{%- endif %}
{{ OperatorHandler.print(state, item) }}
{%- endfor %}
{%- endmacro %}

{# Utility functions for dataType conversions #}
{% macro Collect(context, toCollect)%}SELECT collect_list(struct(*)) AS _val FROM ({{ toCollect }}){% if context == 'Unfiltered' %}{% else %} GROUP BY {{ GetIDFromContext(context) }}{% endif %}{% endmacro %}
{% macro Decollect(context, toDecollect) %}SELECT col.* FROM (SELECT explode(*) FROM ({{ toDecollect }})){% endmacro %}
{% macro Encapsulate(context, toEncapsulate) %}SELECT {{ toEncapsulate }} _val{% endmacro %}
{%- macro coerce(originalType, targetType, state, arguments) %}
{%- if targetType == 'ENCAPSULATED' %}
{%- if originalType == 'SIMPLE' %}
{{ Encapsulate(context, arguments['operator'].print(state, arguments)) }}
{%- elif originalType == 'TABLE' %}
{{ Collect(context, arguments['operator'].print(state, arguments)) }}
{%- else %}
{{ expression }}
{%- endif %}
{%- elif targetType == 'TABLE' %}
{%- if originalType == 'ENCAPSULATED' %}
{{ Decollect(context, arguments['operator'].print(state, arguments)) }}
{%- else %}
{{ arguments['operator'].print(state, arguments) }}
{%- endif %}
{%- else %}
{{ arguments['operator'].print(state, arguments) }}
{%- endif %}
{%- endmacro %}
{%- macro printCoercingIfApplicable(state, arguments) %}
{%- if state != none and state.coercionInstructions != none and state.coercionInstructions[arguments['operator'].dataType] != none %}
{{ coerce(arguments['operator'].dataType, state.coercionInstructions[arguments['operator'].dataType], state, arguments) }}
{%- else %}
{{ arguments['operator'].print(state, arguments) }}
{%- endif %}
{%- endmacro %}

{# Namespace that handles printing operators #}
{% set OperatorHandler = namespace() %}
{% set OperatorHandler.print = printCoercingIfApplicable %}

{# Default operator - printed by java transpiler for operators it doesn't support yet #}
{% set Default = namespace() %}
{% set Default.dataType = 'UNKNOWN' %}
{%- macro printDefault(state, arguments) %}
/* Unsupported operator: <{{ arguments['unsupportedOperator'] }}> with children:[*/{{ ArgumentListPrintingUtility(state, arguments['children'], ", ") }}/*]*/ 
{%- endmacro %}
{% set Default.print = printDefault %}

