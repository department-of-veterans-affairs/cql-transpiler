{# UTILITY AND HELPER FUNCTIONS #}

{# Utility function to get the column a context should be grouped by #}
{% macro GetIDFromContext(context) %}{{ context }}id{% endmacro %}

{# Utility function for printing lists #}
{% macro ListPrintingUtility(listOfItemsToPrint, joiner) %}{% set ns = namespace(first = true) %}{% for item in listOfItemsToPrint %}{% if ns.first %}{% set ns.first = false %}{% else %}{{ joiner }}{% endif %}{{ item }}{% endfor %}{% endmacro %}

{# Utility functions for dataType conversions #}
{% macro Collect(context, toCollect)%}SELECT collect_list(struct(*)) AS _val FROM ({{ toCollect }}){% if context == 'Unfiltered' %}{% else %} GROUP BY {{ GetIDFromContext(context) }}{% endif %}{% endmacro %}
{% macro Decollect(context, toDecollect) %}SELECT col.* FROM (SELECT explode(*) FROM ({{ toDecollect }})){% endmacro %}
{% macro coerce(originalType, targetType, state, arguments) %}{% if targetType == 'ENCAPSULATED' %}{% if originalType == 'SIMPLE' %}{{ _macros_sparksql.Encapsulate(arguments['operator'].print(state, arguments)) }}{% elif originalType == 'TABLE' %}{{ _macros_sparksql.Collect(context, arguments['operator'].print(state, arguments)) }}{% else %}{{ expression }}{% endif %}{% elif targetType == 'TABLE' %}{% if originalType == 'ENCAPSULATED' %}{{ _macros_sparksql.Decollect(context, arguments['operator'].print(state, arguments)) }}{% else %}{{ arguments['operator'].print(state, arguments) }}{% endif %}{% else %}{{ arguments['operator'].print(state, arguments) }}{% endif %}{% endmacro %}
{% macro printCoercingIfApplicable(state, arguments) %}{% if (state != none) and (state.coercionInstructions != none) and (state.coercionInstructions[arguments['operator'].dataType] != none) %}{{ coerce(arguments['operator'].dataType, state.coercionInstructions[arguments['operator'].dataType], state, arguments) }}{% else %}{{ arguments['operator'].print(state, arguments) }}{% endif %}{% endmacro %}

{# Namespace that handles printing operators #}
{% set OperatorHandler = namespace() %}
{% set OperatorHandler.print = printCoercingIfApplicable %}

{# OPERATOR IMPLEMENTATIONS #}

{# Add operator #}
{% set Add = namespace() %}
{% set Add.dataType = 'SIMPLE' %}
{% macro printAdd(state, arguments) %}({{ OperatorHandler.print(state, arguments['children'][0])}} + {{ OperatorHandler.print(state, arguments['children'][1]) }}){% endmacro %}
{% set Add.print = printAdd %}

{# Divide operator #}
{% set Divide = namespace() %}
{% set Divide.dataType = 'SIMPLE' %}
{% macro printDivide(state, arguments) %}({{ OperatorHandler.print(state, arguments['children'][0])}} / {{ OperatorHandler.print(state, arguments['children'][1]) }}){% endmacro %}
{% set Divide.print = printDivide %}
{# OBSOLETE OPERATOR IMPLEMENTATIONS #}

{# ExpressionDef operator #}
{% set ExpressionDef = namespace() %}
{% set ExpressionDef.dataType = 'INHERITED' %}
{% macro printExpressionDef(state, arguments) %}{% if state.context == none and arguments['context'] != none %}{% set state.context = arguments['context'] %}{% endif %}{{ OperatorHandler.print(state, arguments['children'][0]) }}{% endmacro %}
{% set ExpressionDef.print = printExpressionDef %}

{# ExpressionRef operator #}
{% set ExpressionRef = namespace() %}
{% set ExpressionRef.dataType = 'INHERITED' %}
{% macro printExpressionRef(state, arguments) %}{{ arguments['reference'](state) }}{% endmacro %}
{% set ExpressionRef.print = printExpressionRef %}

{# Literal operator #}
{% set Literal = namespace() %}
{% set Literal.dataType = 'SIMPLE' %}
{% macro printLiteral(state, arguments) %}{% if arguments['type'] == 'Integer' %}{{ arguments['value'] }}{% elif arguments['type'] == 'String' %}'{{ arguments['value'] }}'{% else %}{{ arguments['type'] }}::{{ arguments['value'] }}{% endif %}{% endmacro %}
{% set Literal.print = printLiteral %}

{# Multiply operator #}
{% set Multiply = namespace() %}
{% set Multiply.dataType = 'SIMPLE' %}
{% macro printMultiply(state, arguments) %}({{ OperatorHandler.print(state, arguments['children'][0]) }} * {{ OperatorHandler.print(state, arguments['children'][1]) }}){% endmacro %}
{% set Multiply.print = printMultiply %}

{# Subtract operator #}
{% set Subtract = namespace() %}
{% set Subtract.dataType = 'SIMPLE' %}
{% macro printSubtract(state, arguments) %}({{ OperatorHandler.print(state, arguments['children'][0]) }} - {{ OperatorHandler.print(state, arguments['children'][1]) }}){% endmacro %}
{% set Subtract.print = printSubtract %}

{# OBSOLETE OPERATOR IMPLEMENTATIONS #}

{% macro Negate(value) %}(-{{ value }}){% endmacro %}
{% macro Equal(left, right) %}({{left}} = {{ right }}){% endmacro %}
{% macro Retrieve(modeltype, valueset, model) %}SELECT * FROM {{ model }}{% endmacro %}
{% macro Encapsulate(toEncapsulate) %}SELECT {{ toEncapsulate }} _val{% endmacro %}
{% macro TupleElement(name, value)%}{{ value }} AS {{ name }}{% endmacro %}
{% macro Tuple(listOfTupleElements)%}SELECT struct(*) AS _val FROM ({{ ListPrintingUtility(listOfTupleElements, ', ') }}){% endmacro %}
{% macro EmptyTable() %}SELECT * FROM (SELECT 1 _val) WHERE _val = 0{% endmacro %}
{% macro Union(valList, valTypeList) %}{{ ListPrintingUtility(valList, ' UNION ') }}{% endmacro %}
{% macro List(listOfItems) %}SELECT collect_list(_val) AS _val FROM ({% if listOfItems|length == 0 %}{{ EmptyTable() }}{% else %}{{ Union(listOfItems, none) }}{% endif %}){% endmacro %}
{% macro Property(type, scope, path, source) %}{% if type == 'COLUMN_REFERENCE' %}{% if source != none %}{{ source }}.{{ path }}{% elif path != none %}{{ scope }}.{{ path }}{% else %}{{ scope }}{% endif %}{% else %}SELECT {{ path }} FROM ({{ source }}){% endif %}{% endmacro %}
{% macro Concatenate(valList, valTypeList)%}concat({{ ListPrintingUtility(valList, ', ') }}){% endmacro %}
{% macro DateTime(year, month, day, hour, minute, second, millisecond) %}{{ year }}-{{ month }}-{{ day }} {{ hour }}:{{ minute }}:{{ second }}.{{ millisecond }}{% endmacro %}
{% macro AliasedQuerySource(alias, source) %}{{ source }} AS {{ alias }}{% endmacro %}
{% macro GreaterThan (left, right) %}({{ left }} > {{ right }}){% endmacro %}
{% macro LessThan (left, right) %}({{ left }} < {{ right }}){% endmacro %}
{% macro Equals (left, right) %}({{ left }} = {{ right }}){% endmacro %}
{% macro Start(value) %}{{ Property('COLUMN_REFERENCE', none, 'low', value) }}{% endmacro%}
{% macro End(value) %}{{ Property('COLUMN_REFERENCE', none, 'high', value) }}{% endmacro%}
{% macro After(left, right) %}{{ GreaterThan(left, right) }}{% endmacro %}
{% macro Before(left, right) %}{{ LessThan(left, right) }}{% endmacro %}
{% macro Count(context, val) %}{% if context == 'Unfiltered' %}SELECT count({{ val }}) _val{% else %}SELECT count(*) AS _val FROM ({{ val }}) GROUP BY {{ GetIDFromContext(context) }}{% endif %}{% endmacro%}
{% macro ToDecimal(val) %}{{ Add(val, 0.0) }}{% endmacro %}
{% macro ReturnClause(returnList) %}{{ val }}{% if returnList == none %}*{% else %}{{ ListPrintingUtility(returnList, ", ") }}{% endif %}{% endmacro %}
{% macro SortClause(sortByItemList) %}ORDER BY {{ ListPrintingUtility(sortByItemList, ", ") }}{% endmacro %}
{% macro ByExpression(direction, expr) %}{{ expr }} {{ direction }}{% endmacro %}
{% macro Query(letList, sourceList, return, where, sortClause) %}SELECT {% if return == none %}*{% else %}{{ return }}{% endif %} FROM ({{ ListPrintingUtility(sourceList, ", ") }}){% if where != none %} WHERE {{ where }} {% endif %}{% if sortClause != none %} {{ sortClause }}{% endif %}{% endmacro %}
{% macro IdentifierRef(name) %}{{ name }}{% endmacro %}
{% macro And(left, right) %}({{ left }}) AND ({{ right }}){% endmacro %}
{% macro Or(left, right) %}({{ left }}) OR ({{ right }}){% endmacro %}
{% macro LessOrEqual(left, right) %}({{ left }}) <= ({{ right }}){% endmacro %}
{% macro In(left, right) %}({{ left }}) IN ({{ right }}){% endmacro %}
{% macro DifferenceBetween(left, right) %}({{ right }}) - ({{ left }}){% endmacro %}
{% macro ParameterRef(val) %}@{{ val }}{% endmacro %}
{% macro SingletonFrom(val) %}{{ val }}{% endmacro %}