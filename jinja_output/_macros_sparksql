        Public:
            construct(stateNamespace)
            coercionInstructions
            context
            insideQuery
            functionArguments
            insideSqlComment
#}

{%- set StateClass = namespace() %}
{%- macro stateClassConstruct(stateNamespace) %}
{%-     set stateNamespace.coercionInstructions = {} %}
