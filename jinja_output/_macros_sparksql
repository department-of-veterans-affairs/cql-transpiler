{%-     set stateNamespace.functionArguments = {} %}
{%-     set stateNamespace.insideSqlComment = false %}
{%- endmacro %}
{%- set StateClass.construct = stateClassConstruct %}

{#
    CLASS - Operator

    Members:
        Public:
            construct(operatorNamespace)
            print(this, state, arguments)
