{# Prints items from a list, delimiting them with a joiner #}
{%- macro printItemsFromList(listOfItemsToPrint, joiner) %}
{%-     set ns = namespace(first = true) %}
{%-     for item in listOfItemsToPrint %}
{%-         if ns.first %}
{%-             set ns.first = false %}
{%-         else %}
