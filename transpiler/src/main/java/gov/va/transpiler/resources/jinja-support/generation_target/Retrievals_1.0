{% import 'macros' as macros %}
{#
    define testLiteral: 1
#}
{% macro testLiteral() %}{{ macros.Literal('Integer', '1') }}{% endmacro %}
{#
    define testReference: testLiteral
#}
{% macro testReference() %}{{ testLiteral() }}{% endmacro %}
{#
    define testEmptyList: {}
#}
{% macro testEmptyList() %}{{ macros.List([]) }}{% endmacro %}
{#
    define testList: {1, 2}
#}
{% macro testList() %}{{ macros.List([macros.Encapsulate(macros.Literal('Integer', '1')), macros.Encapsulate(macros.Literal('Integer', '2'))]) }}{% endmacro %}
{#
    define testRetrieve: ["Encounter, Performed"]
#}
{% macro testRetrieve() %}{{ macros.Retrieve('urn:healthit-gov:qdm:v5_6', none, 'PositiveEncounterPerformed') }}{% endmacro %}
{#
    define testTuple_withCollection: {foo: testRetrieve, bar: 1}
#}
{% macro testTuple_withCollection() %}{{ macros.Tuple([macros.TupleElement('foo', macros.Collect('Unfiltered', testRetrieve())), macros.TupleElement('bar', macros.Encapsulate(macros.Literal('Integer', '1')))]) }}{% endmacro %}
{#
	define testTupleReference: testTuple_withCollection.bar
#}
{% macro testTupleReference() %}{{ macros.Property('ENCAPSULATED_SIMPLE', none, 'bar', testTuple_withCollection()) }}{% endmacro %}
{#
    define testTupleReference_decollecting: testTuple_withCollection.foo
#}
{% macro testTupleReference_decollecting() %}{{ macros.Decollect('Unfiltered', macros.Property('TABLE', none, 'foo', testTuple_withCollection())) }}{% endmacro %}
{#
    define testNestedTuple: {baz: 1, foobar: testTuple_withCollection}
#}
{% macro testNestedTuple() %}{{ macros.Tuple([macros.TupleElement('baz', macros.Encapsulate(macros.Literal('Integer', '1'))), macros.TupleElement('foobar', testTuple_withCollection())]) }}{% endmacro %}
{#
    define testNestedTupleReference: testNestedTuple.foobar.bar
#}
{% macro testNestedTupleReference() %}{{ macros.Property('ENCAPSULATED_SIMPLE', none, 'bar', macros.Property('ENCAPSULATED_SIMPLE', none, 'foobar', testNestedTuple())) }}{% endmacro %}
{#
    define testNestedTupleReferenceTable: testNestedTuple.foobar.foo
#}
{% macro testNestedTupleReferenceTable() %}{{ macros.Decollect('Unfiltered', macros.Property('TABLE', none, 'foo', macros.Property('ENCAPSULATED_SIMPLE', none, 'foobar', testNestedTuple()))) }}{% endmacro %}
{#
    define function testFunction(val Integer):
        2 * val
#}
{% macro testFunction(val) %}{{ macros.Multiply(macros.Literal('Integer', '2'), val) }}{% endmacro %}
{#
    define testFunctionReference = testFunction(1)
#}
{% macro testFunctionReference() %}{{ testFunction(macros.Encapsulate(macros.Literal('Integer', '1'))) }}{% endmacro %}
{#
    define testConcatenate: '1' + '2'
#}
{% macro testConcatenate() %}{{ macros.Concatenate([macros.Literal('String', '1'), macros.Literal('String', '2')], ['SIMPLE', 'SIMPLE']) }}{% endmacro %}
{#
    define testMathOperations: (1 + 2 / -3 + 4) * 5 + testLiteral()
#}
{% macro testMathOperations() %}{{ macros.Add(macros.Multiply(macros.Add(macros.Add(macros.ToDecimal(macros.Literal('Integer', '1')), macros.Divide(macros.ToDecimal(macros.Literal('Integer', '2')), macros.ToDecimal(macros.Negate(macros.Literal('Integer', '3'))))), macros.ToDecimal(macros.Literal('Integer', '4'))), macros.ToDecimal(macros.Literal('Integer', '5'))), macros.ToDecimal(testLiteral())) }}{% endmacro %}
{#
    define testDateTime: @2010-01-02T14:30:07.76
#}
{% macro testDatetime() %}{{ macros.DateTime(macros.Literal('Integer', '2010'), macros.Literal('Integer', '1'), macros.Literal('Integer', '2'), macros.Literal('Integer', '14'), macros.Literal('Integer', '30'), macros.Literal('Integer', '7'), macros.Literal('Integer', '76')) }}{% endmacro %}
{#
    define testQuery_returnColumnValue: ["Encounter, Performed"] E return E.period
#}
{% macro testQuery_returnColumnValue() %}{{ macros.Query([macros.AliasedQuerySource('E', macros.Retrieve('urn:healthit-gov:qdm:v5_6', none, 'PositiveEncounterPerformed'))], [macros.ReturnClause(macros.Property('COLUMN_REFERENCE', 'E', 'relevantPeriod', none))], none, []) }}{% endmacro %}
{#
    define testQuery_withWhere: ["Encounter, Performed"] E where E.period ends after testDate
#}
{% macro testQuery_withWhere() %}{{ macros.Query('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed', 'E', none, macros.After(macros.Property("COLUMN_REFERENCE", 'period', 'E', none), testDatetime()), none) }}{% endmacro %}
{#
    define testQuery_sortBy: ["Encounter, Performed"] E sort by status.value
#}
{% macro testQuery_withSortBy() %}{{ macros.Query('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed', 'E', none, none, [macros.Property("COLUMN_REFERENCE", 'value', 'status', none)]) }}{% endmacro %}
{#
    define testQuery_returnColumnValueProperty: ["Encounter, Performed"] E return E.status.value
#}
{% macro testQuery_returnColumnValueProperty() %}{{ macros.Query('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed', 'E', [macros.Property("COLUMN_REFERENCE", macros.Property("COLUMN_REFERENCE", 'value', 'status', none), 'E', NONE)], none, none) }}{% endmacro %}
{#
    define testQuery_wherePropertyMatch: ["Encounter, Performed"] E where E.period.status = 'finished'
#}
{% macro testQuery_wherePropertyMatch() %}{{ macros.Query('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed', 'E', none, macros.Equals(macros.Property("COLUMN_REFERENCE", 'E', macros.Property("COLUMN_REFERENCE", 'status', 'period', none)), 'finished'), none) }}{% endmacro %}
{#
    define testUnion: ["Encounter, Performed"] union [Patient]
#}
{% macro testUnion() %}{{ macros.Union([macros.Retrieve('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed'), macros.Retrieve('URN:HEALTHIT-GOV:QDM:V5_6', none, 'Patient')]) }}{% endmacro %}
{#
    context Patient
    define testCount_patientContext: Count(["Encounter, Performed"])
#}
{% macro testCount_patientContext() %}{{ macros.Count('Patient', true, macros.Retrieve('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed')) }}{% endmacro %}
{#
    context Unfiltered
    define testCount_unfilteredContext: Count(["Encounter, Performed"])
#}
{% macro testCount_unfilteredContext() %}{{ macros.Count('Unfiltered', true, macros.Retrieve('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed')) }}{% endmacro %}