{% import 'macros' as macros %}
{#
    define testLiteral: 1
#}
{% macro testLiteral() %}{{ macros.Literal('Integer', '1') }}{% endmacro %}
{#
    define testReference: testLiteral
#}
{% macro testReference() %}{{ testLiteral() }}{% endmacro %}
{#
    define testEmptyList: {}
#}
{% macro testEmptyList() %}{{ macros.List([]) }}{% endmacro %}
{#
    define testList: {1, 2}
#}
{% macro testList() %}{{ macros.List([macros.Encapsulate(macros.Literal('Integer', '1')), macros.Encapsulate(macros.Literal('Integer', 2))]) }}{% endmacro %}
{#
    define testRetrieve: ["Encounter, Performed"]
#}
{% macro testRetrieve() %}{{ macros.Retrieve('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed') }}{% endmacro %}
{#
    define testTuple_withCollection: {foo: testRetrieve, bar: 1}
#}
{% macro testTuple_withCollection() %}{{ macros.Tuple([macros.TupleElement('foo', macros.Collect('Unfiltered', testRetrieve())), macros.TupleElement('bar', macros.Encapsulate('1'))]) }}{% endmacro %}
{#
    define testTupleReference: testTuple_withCollection.bar
#}
{% macro testTupleReference() %}{{ macros.PropertyOf(false, 'bar', testTuple_withCollection()) }}{% endmacro %}
{#
    define testTupleReference_decollecting: testTuple_withCollection.foo
#}
{% macro testTupleReference_decollecting() %}{{ macros.Decollect(macros.PropertyOf(false, 'foo', testTuple_withCollection())) }}{% endmacro %}
{#
    define testNestedTuple: {baz: 1, foobar: testTuple_withCollection}
#}
{% macro testNestedTuple() %}{% set paramList=['baz', 'foobar'] %}{% set currentDict=({'baz': macros.Encapsulate(1), 'foobar': testTuple_withCollection()}) %}{{ macros.Tuple(paramList, currentDict) }}{% endmacro %}
{#
    define testNestedTupleReference: TestNestedTuple.foobar.bar
#}
{% macro testNestedTupleReference() %}{{ macros.PropertyOf(false, 'bar', macros.PropertyOf(false, 'foobar', testNestedTuple())) }}{% endmacro %}
{#
    define testNestedTupleReferenceTable: TestNestedTuple.foobar.food
#}
{% macro testNestedTupleReferenceTable() %}{{ macros.Decollect(macros.PropertyOf(false, 'foo', macros.PropertyOf(false, 'foobar', testNestedTuple()))) }}{% endmacro %}
{#
    define function testFunction(val Integer):
#}
{% macro testFunction(val) %}{{ macros.Multiply(macros.Literal('Integer', '2'), val) }}{% endmacro %}
{#
    define testFunctionReference = testFunction(1):
#}
{% macro testFunctionReference() %}{{ testFunction(macros.Literal('Integer', '1')) }}{% endmacro %}
{#
    define testConcatenate: '1' + '2'
#}
{% macro testConcatenate() %}{{ macros.Concatenate(macros.Literal('String', '1'), true, macros.Literal('String', '2'), true) }}{% endmacro %}
{#
    define testMathOperations: (1 + 2 / -3 + 4) * 5 + testLiteral()
#}
{# note: this is missing a lot of 'to decimal' calls #}
{% macro testMathOperations() %}{{ macros.Add(macros.Multiply(macros.Add(macros.Add(macros.Literal('Integer', 1), macros.Divide(macros.Literal('Integer', '2'), macros.Negate(macros.Literal('Integer', 3)))), macros.Literal('Integer', '4')), macros.Literal('Integer', '5')), testLiteral()) }}{% endmacro %}
{#
    define testDatetime: @2010-01-02T14:30:07.76
#}
{% macro testDatetime() %}{{ macros.Datetime(macros.Literal('Integer', '2010'), macros.Literal('Integer', '01'), macros.Literal('Integer', '02'), macros.Literal('Integer', '14'), macros.Literal('Integer', '30'), macros.Literal('Integer', '7'), macros.Literal('Integer', '76')) }}{% endmacro %}
{#
    define testQuery_returnColumnValue: ["Encounter, Performed"] E return E.period
#}
{% macro testQuery_returnColumnValue() %}{{ macros.Query('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed', 'E', [macros.PropertyOf(true, 'period', 'E')], none, none) }}{% endmacro %}
{#
    define testQuery_withWhere: ["Encounter, Performed"] E where E.period ends after testDate
#}
{% macro testQuery_withWhere() %}{{ macros.Query('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed', 'E', none, macros.After(macros.PropertyOf(true, 'period', 'E'), testDatetime()), none) }}{% endmacro %}
{#
    define testQuery_sortBy: ["Encounter, Performed"] E sort by status.value
#}
{% macro testQuery_withSortBy() %}{{ macros.Query('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed', 'E', none, none, [macros.PropertyOf(true, 'value', 'status')]) }}{% endmacro %}
{#
    define testQuery_returnColumnValueProperty: ["Encounter, Performed"] E return E.status.value
#}
{% macro testQuery_returnColumnValueProperty() %}{{ macros.Query('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed', 'E', [macros.PropertyOf(true, macros.PropertyOf(true, 'value', 'status'), 'E')], none, none) }}{% endmacro %}
{#
    define testQuery_wherePropertyMatch: ["Encounter, Performed"] E where E.period.status = 'finished'
#}
{% macro testQuery_wherePropertyMatch() %}{{ macros.Query('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed', 'E', none, macros.Equals(macros.PropertyOf(true, 'value', macros.PropertyOf(true, 'status', 'E')), 'finished'), none) }}{% endmacro %}
{#
    define testUnion: ["Encounter, Performed"] union [Patient]
#}
{% macro testUnion() %}{{ macros.Union([macros.Retrieve('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed'), macros.Retrieve('URN:HEALTHIT-GOV:QDM:V5_6', none, 'Patient')]) }}{% endmacro %}
{#
    context Patient
    define testCount_patientContext: Count(["Encounter, Performed"])
#}
{% macro testCount_patientContext() %}{{ macros.Count('Patient', true, macros.Retrieve('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed')) }}{% endmacro %}
{#
    context Unfiltered
    define testCount_unfilteredContext: Count(["Encounter, Performed"])
#}
{% macro testCount_unfilteredContext() %}{{ macros.Count('Unfiltered', true, macros.Retrieve('URN:HEALTHIT-GOV:QDM:V5_6', none, 'PositiveEncounterPerformed')) }}{% endmacro %}