{% import 'macros' as macros %}

{#
    define testLiteral: 1
#}
{% macro testLiteral() %}{{ macros.literal('Integer', '1') }}{% endmacro %}

{#
    define testReference: a
#}
{% macro testReference() %}{{ testLiteral() }}{% endmacro %}

{#
    define testRetrieve: [Patient]
#}
{% macro testRetrieve() %}{{ macros.retrieve('QUICK', 'Patient') }}{% endmacro %}

{#
    define testStruct_WithCompression: {foo: c, bar: 1}
#}
{% macro testStruct_WithCompression() %}{% set paramList=['foo', 'bar'] %}{% set currentDict=({'foo': macros.compress('Unfiltered', testRetrieve()), 'bar': macros.encapsulate(macros.literal('Integer', '1'))}) %}{{ macros.struct(paramList, currentDict) }}{% endmacro %}

{#
    define testEmptyList: {}
#}
{% macro testEmptyList() %}{{ macros.list([]) }}{% endmacro %}

{#
    define testList: {1, 2}
#}
{% macro testList() %}{{ macros.list([macros.encapsulate(macros.literal('Integer', '1')), macros.encapsulate(macros.literal('Integer', 2))]) }}{% endmacro %}

{#
    define testStructReference: testStruct_WithCompression.bar
#}
{% macro testStructReference() %}SELECT bar from ({{ testStructWithCompression() }}){% endmacro %}

{#
    define testStructReference_decompressing: testStruct_WithCompression.foo
#}
{% macro testStructReference() %}SELECT foo from ({{ macros.decompress(testStructWithCompression) }}){% endmacro %}

{#
    define testNestedStruct: {baz: 1, foobar: testStruct_WithCompression}
#}
{% macro testNestedStruct() %}{% set paramList=['baz', 'foobar'] %}{% set currentDict=({'baz': encapsulate(1), 'bar': testStruct_withCompression()}) %}{{ macros.struct(paramList, currentDict) }}{% endmacro %}

