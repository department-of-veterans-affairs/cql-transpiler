{% import 'macros' as macros %}

{#
    define testLiteral: 1
#}
{% macro testLiteral() %}{{ macros.literal('Integer', '1') }}{% endmacro %}

{#
    define testReference: a
#}
{% macro testReference() %}{{ testLiteral() }}{% endmacro %}

{#
    define testRetrieve: [Patient]
#}
{% macro testRetrieve() %}{{ macros.retrieve('QUICK', 'Patient') }}{% endmacro %}

{#
    define testStruct_withCompression: {foo: c, bar: 1}
#}
{% macro testStruct_withCompression() %}{% set paramList=['foo', 'bar'] %}{% set currentDict=({'foo': macros.compress('Unfiltered', testRetrieve()), 'bar': macros.encapsulate(macros.literal('Integer', '1'))}) %}{{ macros.struct(paramList, currentDict) }}{% endmacro %}

{#
    define testEmptyList: {}
#}
{% macro testEmptyList() %}{{ macros.list([]) }}{% endmacro %}

{#
    define testList: {1, 2}
#}
{% macro testList() %}{{ macros.list([macros.encapsulate(macros.literal('Integer', '1')), macros.encapsulate(macros.literal('Integer', 2))]) }}{% endmacro %}

{#
    define testStructReference: testStruct_withCompression.bar
#}
{% macro testStructReference() %}SELECT bar from ({{ testStruct_withCompression() }}){% endmacro %}

{#
    define testStructReference_decompressing: testStruct_withCompression.foo
#}
{% macro testStructReference() %}SELECT foo from ({{ macros.decompress(testStruct_withCompression()) }}){% endmacro %}

{#
    define testNestedStruct: {baz: 1, foobar: testStruct_withCompression}
#}
{% macro testNestedStruct() %}{% set paramList=['baz', 'foobar'] %}{% set currentDict=({'baz': macros.encapsulate(1), 'foobar': testStruct_withCompression()}) %}{{ macros.struct(paramList, currentDict) }}{% endmacro %}

{#
    define testNestedStructReference: TestNestedStruct.foobar.bar
#}
{% macro testNestedStructReference() %}{{ macros.propertyOf('bar', macros.propertyOf('foobar', testNestedStruct())) }}{% endmacro %}

{#
    define testNestedStructReferenceTable: TestNestedStruct.foobar.food
#}
{% macro testNestedStructReferenceTable() %}{{ macros.decompress(macros.propertyOf('foo', macros.propertyOf('foobar', testNestedStruct()))) }}{% endmacro %}

{#
    define function testFunction(val Integer):
#}
{% macro testFunction(val) %}{{ macros.multiply(macros.literal('Integer', '2'), val) }}{% endmacro %}

{#
    define testFunctionReference = testFunction(1):
#}
{% macro testFunctionReference() %}{{ testFunction(macros.literal('Integer', '1')) }}{% endmacro %}

{#
    define testConcatenate_simpleValues: '1' + '2'
#}
{% macro testConcatenate_simpleValues() %}{{ macros.concatenate(macros.literal('String', '1'), true, macros.literal('String', '2'), true) }}{% endmacro %}
