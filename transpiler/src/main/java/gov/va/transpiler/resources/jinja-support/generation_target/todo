{# to implement macros for #}

{#
    define testUnion: [Encounter] union [Patient]
#}
{% macro testUnion() %}{{ macros.union([macros.retrieve('QUICK', 'Encounter'), macros.retrieve('QUICK', 'Patient')]) }}{% endmacro %}

{#
    context Patient
    define testCount_patientContext: Count([Encounter])
#}
{% macro testCount_patientContext() %}{{ macros.count('Patient', macros.retrieve('QUICK', 'Encounter')) }}{% endmacro %}

{#
    context Unfiltered
    define testCount_unfilteredContext: Count([Encounter])
#}
{% macro testCount_unfilteredContext() %}{{ macros.count('Encounter', macros.retrieve('QUICK', 'Encounter')) }}{% endmacro %}

{#
    library Retrievals version '1.0'
    using QDM version '5.6'
    include MATGlobalCommonFunctions version '7.0.000' called Global
    valueset "Nonelective Inpatient Encounter": 'urn:oid:2.16.840.1.113883.3.117.1.7.1.424'
    parameter "Measurement Period" Interval<DateTime>
    define "Non Elective Inpatient Encounter":
        ["Encounter, Performed": "Nonelective Inpatient Encounter"] NonElectiveEncounter
            where Global."LengthInDays" ( NonElectiveEncounter.relevantPeriod ) <= 120
            and NonElectiveEncounter.relevantPeriod ends during day of "Measurement Period"
#}
{% macro Non_Elective_Inpatient_Encounter() %}{{  macros.query_source_alias_where('QDM', 'Encounter, Performed', 'Nonelective Inpatient Encounter', 'NonElectiveEncounter', macros.where(macros.and(macros.lessThan(Global.LengthInDays(macros.propertyOf('relevantPeriod', 'NonElectiveEncounter')), macros.literal('Integer', '120')), macros.and(macros.lessThan(macros.end('QDM', macros.propertyOf('relevantPeriod', 'NonElectiveEncounter')), macros.end('QDM', macros.parameterReference('Measurement Period'))), macros.greaterThan(macros.end('QDM', macros.propertyOf('relevantPeriod', 'NonElectiveEncounter')), macros.start('QDM', macros.parameterReference('Measurement Period'))))))) }}{% endmacro %}