{% macro literal(literalType, value) %}{% if literalType == 'Integer' %}{{value}}{% elif literalType == 'String' %}'{{value}}'{% else %}{{literalType}}::{{value}}{% endif %}{% endmacro %}
{% macro add(left, right) %}{{left}} + {{right}}{% endmacro %}
{% macro subtract(left, right) %}{{left}} - {{right}}{% endmacro %}
{% macro multiply(left, right) %}{{left}} * {{right}}{% endmacro %}
{% macro divide(left, right) %}{{left}} / {{right}}{% endmacro %}
{% macro retrieve(modeltype, model) %}SELECT * FROM {{ model }}{% endmacro %}
{% macro compress(toCompress)%}SELECT collect_list(struct(*)) AS _val FROM ({{ toCompress }}){% endmacro %}
{% macro encapsulate(toEncapsulate) %}SELECT {{ toEncapsulate }} _val{% endmacro %}
{% macro struct(listOfElements, dictionary)%}{% set ns = namespace(first=true) %}SELECT struct(*) AS _val FROM ({% for element in listOfElements %}{% if ns.first %}{% set ns.first = false %}{% else %}, {% endif %}{{ dictionary[element] }} AS '{{ element }}'{% set first = false %}{% endfor %}){% endmacro %}